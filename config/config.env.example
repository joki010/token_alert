# token_alert 설정 파일
# 이 파일을 config.env 로 복사한 뒤 실제 값을 입력하세요.
# cp config/config.env.example config/config.env

# ─────────────────────────────────────────
# 텔레그램 봇 설정
# 발급 방법: docs/telegram-setup.md 참고
# ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ─────────────────────────────────────────
# GitHub Actions 설정
# 발급 방법: docs/github-setup.md 참고
# ─────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your_github_username
GITHUB_REPO=token_alert

# ─────────────────────────────────────────
# 감지 설정 (선택)
# ─────────────────────────────────────────
# Claude Code 데이터 경로 (기본값: ~/.claude/projects)
# CLAUDE_PROJECTS_DIR=~/.claude/projects

# 감지 주기 (초, 기본값: 600 = 10분)
# POLL_INTERVAL=600

# 알림 여유 시간 (초, 기본값: 0 = 정확히 초기화 시각에 알림)
# NOTIFY_ADVANCE_SECONDS=0
